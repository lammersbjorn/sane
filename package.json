{
  "name": "@sane/workspace",
  "private": true,
  "version": "1.0.0-beta.7",
  "description": "Sane terminal onboarding and setup surface for Codex.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lammersbjorn/sane.git"
  },
  "homepage": "https://github.com/lammersbjorn/sane#readme",
  "bugs": {
    "url": "https://github.com/lammersbjorn/sane/issues"
  },
  "scripts": {
    "start": "pnpm --filter @sane/sane-tui run build:package && node ./apps/sane-tui/dist/bin/sane.js",
    "start:settings": "pnpm --filter @sane/sane-tui run build:package && node ./apps/sane-tui/dist/bin/sane.js settings",
    "start:status": "pnpm --filter @sane/sane-tui run build:package && node ./apps/sane-tui/dist/bin/sane.js status",
    "start:inspect": "pnpm --filter @sane/sane-tui run build:package && node ./apps/sane-tui/dist/bin/sane.js inspect",
    "start:repair": "pnpm --filter @sane/sane-tui run build:package && node ./apps/sane-tui/dist/bin/sane.js repair",
    "pack:sane-tui": "pnpm --filter @sane/sane-tui run build:package && cd apps/sane-tui/dist && pnpm pack",
    "start:ts-live-preview": "pnpm --filter @sane/sane-tui run preview:terminal",
    "start:ts-live-preview:settings": "pnpm --filter @sane/sane-tui run preview:terminal settings",
    "start:ts-preview": "node ./apps/sane-tui/bin/sane.mjs",
    "start:ts-preview:settings": "node ./apps/sane-tui/bin/sane.mjs settings",
    "start:ts-built-preview": "pnpm --filter @sane/sane-tui run build && node ./apps/sane-tui/dist/bin/sane.js",
    "start:ts-built-preview:settings": "pnpm --filter @sane/sane-tui run build && node ./apps/sane-tui/dist/bin/sane.js settings",
    "start:ts-built-preview:status": "pnpm --filter @sane/sane-tui run build && node ./apps/sane-tui/dist/bin/sane.js status",
    "start:ts-built-preview:inspect": "pnpm --filter @sane/sane-tui run build && node ./apps/sane-tui/dist/bin/sane.js inspect",
    "check": "pnpm typecheck && pnpm test",
    "release:verify": "pnpm check && pnpm --filter @sane/sane-tui run build:smoke && pnpm run pack:sane-tui",
    "release:npm:dry-run": "pnpm run release:verify && cd apps/sane-tui/dist && pnpm publish --dry-run --access public --no-git-checks",
    "release:npm:dry-run:beta": "pnpm run release:verify && cd apps/sane-tui/dist && pnpm publish --dry-run --access public --no-git-checks --tag beta",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
